{
  "expo": {
    "name": "Leftover Chef",
    "slug": "leftover-chef",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/IMG_4486.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/IMG_4487.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF6EE"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourcompany.leftoverchef",
      "infoPlist": {
        "NSCameraUsageDescription": "Leftover Chef uses your camera to photograph your fridge or pantry so it can suggest recipes from what you already have.",
        "NSPhotoLibraryUsageDescription": "Leftover Chef needs access to your photos so you can pick an existing photo of your fridge or pantry."
      }
    },
    "android": {
      "package": "com.yourcompany.leftoverchef",
      "adaptiveIcon": {
        "foregroundImage": "./assets/IMG_4488.png",
        "backgroundColor": "#FAF6EE"
      }
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
